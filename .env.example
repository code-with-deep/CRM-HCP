# Application
APP_NAME=Healthcare CRM API
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Database (async driver for application runtime)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crm_hcp

# Database (sync driver for Alembic migrations)
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/crm_hcp

# AI (LangGraph agent)
GROQ_API_KEY=
GROQ_MODEL_NAME=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL_NAME=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=1024
LLM_MAX_VALIDATION_RETRIES=1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=/api
VITE_DEMO_USER_ID=00000000-0000-0000-0000-000000000001
